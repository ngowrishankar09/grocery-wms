# Copy this to /var/www/rapiddockwms/.env on your server and fill in values

# PostgreSQL connection string (from Supabase / Neon / your DB)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret-key
