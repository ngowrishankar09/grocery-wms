[Unit]
Description=RapidDock WMS FastAPI Backend
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/rapiddockwms/backend
EnvironmentFile=/var/www/rapiddockwms/.env
ExecStart=/var/www/rapiddockwms/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
